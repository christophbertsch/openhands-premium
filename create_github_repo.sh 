#!/bin/bash

# GitHub Repository Creation Script for OpenHands Premium Setup
# Run this script with your GitHub token to create and push the repository

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}🚀 OpenHands Premium - GitHub Repository Setup${NC}"
echo

# Check if GitHub token is provided
if [ -z "$GITHUB_TOKEN" ]; then
    echo -e "${YELLOW}Please set your GitHub token:${NC}"
    read -p "Enter your GitHub Personal Access Token: " GITHUB_TOKEN
    export GITHUB_TOKEN
fi

# Repository details
REPO_NAME="openhands-premium-setup"
REPO_DESCRIPTION="Premium-quality local OpenHands setup with enhanced agents, quality analysis, and production features"

echo -e "${BLUE}Repository: $REPO_NAME${NC}"
echo -e "${BLUE}Description: $REPO_DESCRIPTION${NC}"
echo

# Get GitHub username
echo -e "${YELLOW}Getting GitHub user information...${NC}"
GITHUB_USER=$(curl -s -H "Authorization: token $GITHUB_TOKEN" \
                   -H "Accept: application/vnd.github.v3+json" \
                   https://api.github.com/user | jq -r '.login')

if [ "$GITHUB_USER" = "null" ] || [ -z "$GITHUB_USER" ]; then
    echo -e "${RED}❌ Failed to get GitHub user. Please check your token.${NC}"
    exit 1
fi

echo -e "${GREEN}✅ GitHub user: $GITHUB_USER${NC}"

# Create repository
echo -e "${YELLOW}Creating GitHub repository...${NC}"
REPO_RESPONSE=$(curl -s -H "Authorization: token $GITHUB_TOKEN" \
                     -H "Accept: application/vnd.github.v3+json" \
                     -X POST \
                     -d "{
                       \"name\": \"$REPO_NAME\",
                       \"description\": \"$REPO_DESCRIPTION\",
                       \"private\": false,
                       \"has_issues\": true,
                       \"has_projects\": true,
                       \"has_wiki\": true,
                       \"auto_init\": false
                     }" \
                     https://api.github.com/user/repos)

# Check if repository was created successfully
REPO_URL=$(echo "$REPO_RESPONSE" | jq -r '.clone_url')
if [ "$REPO_URL" = "null" ] || [ -z "$REPO_URL" ]; then
    echo -e "${RED}❌ Failed to create repository. Response:${NC}"
    echo "$REPO_RESPONSE" | jq '.'
    exit 1
fi

echo -e "${GREEN}✅ Repository created: $REPO_URL${NC}"

# Add remote and push
echo -e "${YELLOW}Adding remote and pushing code...${NC}"
REPO_SSH_URL="git@github.com:$GITHUB_USER/$REPO_NAME.git"
REPO_HTTPS_URL="https://$GITHUB_TOKEN@github.com/$GITHUB_USER/$REPO_NAME.git"

# Add remote
git remote add origin "$REPO_HTTPS_URL"

# Push to GitHub
echo -e "${YELLOW}Pushing to GitHub...${NC}"
git push -u origin master

echo -e "${GREEN}🎉 Successfully created and pushed to GitHub!${NC}"
echo
echo -e "${BLUE}Repository URL: https://github.com/$GITHUB_USER/$REPO_NAME${NC}"
echo -e "${BLUE}Clone URL: $REPO_URL${NC}"
echo
echo -e "${YELLOW}Next steps:${NC}"
echo -e "1. Visit: https://github.com/$GITHUB_USER/$REPO_NAME"
echo -e "2. Clone on other machines: git clone $REPO_URL"
echo -e "3. Run setup: ./setup_openhands.sh"
echo
echo -e "${GREEN}✅ OpenHands Premium Setup is now available on GitHub!${NC}"